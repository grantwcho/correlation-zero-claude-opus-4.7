{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Query Envelope",
  "type": "object",
  "required": ["query_id", "response_format"],
  "properties": {
    "query_id": { "type": "string" },
    "response_format": { "type": "string" },
    "metrics": {
      "type": "array",
      "items": { "type": "string" }
    },
    "context": { "type": "object" }
  }
}

